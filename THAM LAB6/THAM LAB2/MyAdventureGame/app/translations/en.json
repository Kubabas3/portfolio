    "draw": {
      "text": "Draw! Roll the dice again!",
      "choices": [
        { "text": "🎲 Roll again", "next": "fight" },
        { "text": "🏃 Run away", "next": "start" }
      ]
    }
  },
  "alerts": {
    "victory": "Victory!",
    "defeat": "Defeat!",
    "draw": "Draw!",
    "victoryMessage": "You defeated the enemy!",
    "defeatMessage": "You lost...",
    "drawMessage": "Draw! Roll again."
  }
