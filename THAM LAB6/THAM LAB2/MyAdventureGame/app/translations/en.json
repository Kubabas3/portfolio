{
  "gameTitle": "🏰 My Adventure",
  "scenes": {
    "start": {
      "text": "Welcome to the game! You stand at a crossroads. Where will you go?",
      "choices": [
        { "text": "Left", "next": "left" },
        { "text": "Right", "next": "right" }
      ]
    },
    "left": {
      "text": "You went left and encountered a dragon! It wants to fight you.",
